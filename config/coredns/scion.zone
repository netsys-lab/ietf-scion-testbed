$ORIGIN scion.
$TTL 300
@ 3600 IN SOA scitra.netsys.ovgu.de. lschulz.ovgu.de. 2026071401 7200 3600 1209600 3600
@ IN NS scitra.netsys.ovgu.de.
; scion= TXT on every SCION-capable name (discovery via dig TXT; scitra input).
; Safe alongside A/AAAA since scitra dd03a3ffe: native records take precedence,
; fc00 synthesis only fills SCION-only names. REQUIRES that coredns build or
; newer — deploy the binary with/before this zone.
; dual-homed (IP race legs): TXT scion= matches the SVCB scion= param byte-for-byte
; (the address the SCION service listens on; no SCMP responder there — scion ping
; wants the mgmt addr instead).
; Fabric addresses are STATIC (BGP fabric, spec 2026-07-11-bgp-fabric) — the
; old venue-IP zone-sync is retired; nothing rewrites these lines.
web        IN A    10.150.0.80
web        IN AAAA fd00:beef:150::80
web        IN SVCB 1 . alpn=h3,h2 port=443 scion=1-150\,10.150.0.81 scion-policy=bw,latency
web        IN TXT  "scion=1-150,10.150.0.81"
web2       IN A    10.153.0.80
web2       IN AAAA fd00:beef:153::80
web2       IN SVCB 1 . alpn=h3,h2 port=443 scion=1-153\,10.153.0.81
web2       IN TXT  "scion=1-153,10.153.0.81"
; per-AS BGP-fabric anchor names (traceroute/ping demos read as ASes);
; TXT scion= carries the AS CT's mgmt addr — SCMP answers there, so the value
; copy-pastes into `scion ping`.
as150       IN A    10.150.0.1
as150       IN AAAA fd00:beef:150::1
as150       IN TXT  "scion=1-150,10.20.3.150"
as151       IN A    10.151.0.1
as151       IN AAAA fd00:beef:151::1
as151       IN TXT  "scion=1-151,10.20.3.151"
as152       IN A    10.152.0.1
as152       IN AAAA fd00:beef:152::1
as152       IN TXT  "scion=1-152,10.20.3.152"
as153       IN A    10.153.0.1
as153       IN AAAA fd00:beef:153::1
as153       IN TXT  "scion=1-153,10.20.3.153"
as154       IN A    10.154.0.1
as154       IN AAAA fd00:beef:154::1
as154       IN TXT  "scion=1-154,10.20.3.154"
as155       IN A    10.155.0.1
as155       IN AAAA fd00:beef:155::1
as155       IN TXT  "scion=1-155,10.20.3.155"
as156       IN A    10.156.0.1
as156       IN AAAA fd00:beef:156::1
as156       IN TXT  "scion=1-156,10.20.3.156"
as157       IN A    10.157.0.1
as157       IN AAAA fd00:beef:157::1
as157       IN TXT  "scion=1-157,10.20.3.157"
as158       IN A    10.158.0.1
as158       IN AAAA fd00:beef:158::1
as158       IN TXT  "scion=1-158,10.20.3.158"
as159       IN A    10.159.0.1
as159       IN AAAA fd00:beef:159::1
as159       IN TXT  "scion=1-159,10.20.3.159"
as160       IN A    10.160.0.1
as160       IN AAAA fd00:beef:160::1
as160       IN TXT  "scion=1-160,10.20.3.160"
as161       IN A    10.161.0.1
as161       IN AAAA fd00:beef:161::1
as161       IN TXT  "scion=1-161,10.20.3.161"
; SCION-only names: SVCB + TXT (scitra serves fc00 AAAA to plain clients)
; welcome -> svc-151 (CT214, 1-151,10.20.3.214): SCION-only demo name; scitra
; synthesizes the fc00 AAAA from the scion= TXT (no explicit A/AAAA here).
welcome    IN SVCB 1 . alpn=h3 scion=1-151\,10.20.3.214
welcome    IN TXT  "scion=1-151,10.20.3.214"
games      IN SVCB 1 . alpn=h3 scion=71-2:0:4a\,10.44.25.3 scion-policy=latency
games      IN TXT  "scion=71-2:0:4a,10.44.25.3"
matrix.netsys.ovgu   IN TXT "scion=71-2:0:4a,141.44.17.123"
element.netsys.ovgu  IN CNAME matrix.netsys.ovgu.scion.
