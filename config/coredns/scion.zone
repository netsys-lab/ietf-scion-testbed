$ORIGIN scion.
$TTL 300
@ 3600 IN SOA scitra.netsys.ovgu.de. lschulz.ovgu.de. 2026071104 7200 3600 1209600 3600
@ IN NS scitra.netsys.ovgu.de.
; dual-homed (IP race legs): SVCB only — NO scion= TXT (scitra would hijack AAAA)
; Fabric addresses are STATIC (BGP fabric, spec 2026-07-11-bgp-fabric) — the
; old venue-IP zone-sync is retired; nothing rewrites these lines.
web        IN A    10.150.0.80
web        IN AAAA fd00:beef:150::80
web        IN SVCB 1 . alpn=h3,h2 port=443 scion=1-150\,10.150.0.81 scion-policy=bw,latency
web2       IN A    10.153.0.80
web2       IN AAAA fd00:beef:153::80
web2       IN SVCB 1 . alpn=h3,h2 port=443 scion=1-153\,10.153.0.81
; per-AS BGP-fabric anchor names (traceroute/ping demos read as ASes);
; plain A/AAAA only — never scion= TXT (scitra hijack rule)
as150       IN A    10.150.0.1
as150       IN AAAA fd00:beef:150::1
as151       IN A    10.151.0.1
as151       IN AAAA fd00:beef:151::1
as152       IN A    10.152.0.1
as152       IN AAAA fd00:beef:152::1
as153       IN A    10.153.0.1
as153       IN AAAA fd00:beef:153::1
as154       IN A    10.154.0.1
as154       IN AAAA fd00:beef:154::1
as155       IN A    10.155.0.1
as155       IN AAAA fd00:beef:155::1
as156       IN A    10.156.0.1
as156       IN AAAA fd00:beef:156::1
as157       IN A    10.157.0.1
as157       IN AAAA fd00:beef:157::1
as158       IN A    10.158.0.1
as158       IN AAAA fd00:beef:158::1
as159       IN A    10.159.0.1
as159       IN AAAA fd00:beef:159::1
as160       IN A    10.160.0.1
as160       IN AAAA fd00:beef:160::1
as161       IN A    10.161.0.1
as161       IN AAAA fd00:beef:161::1
; SCION-only names: SVCB + TXT (scitra serves fc00 AAAA to plain clients)
games      IN SVCB 1 . alpn=h3 scion=71-2:0:4a\,10.44.25.3 scion-policy=latency
games      IN TXT  "scion=71-2:0:4a,10.44.25.3"
matrix.netsys.ovgu   IN TXT "scion=71-2:0:4a,141.44.17.123"
element.netsys.ovgu  IN CNAME matrix.netsys.ovgu.scion.
