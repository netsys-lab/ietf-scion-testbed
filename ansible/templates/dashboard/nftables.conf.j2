#!/usr/sbin/nft -f
flush ruleset

# Dashboard container (CT200) venue firewall. eth1 is on the venue bridge and
# fabricd binds 0.0.0.0:8080, so without this every 0.0.0.0 service (notably
# ssh) is reachable from the attendee network. The intended venue surface is
# EXACTLY CT200:8080. Output policy is default-accept (no output chain), so
# fabricd's outbound scrapes to AS metrics and its dial to the hub are
# unaffected — only INPUT is restricted.
table inet dashboard {
    chain input {
        type filter hook input priority 0; policy drop;
        iif "lo" accept
        ct state established,related accept
        # v6 housekeeping on the venue leg (SLAAC/ND) and general ICMPv6
        icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert, nd-router-solicit, nd-router-advert, echo-request } accept
        # DHCPv4 client on the venue leg: initial OFFER/ACK arrive as broadcast,
        # which conntrack does not track
        iifname "eth1" udp sport 67 udp dport 68 accept
        # dashboard / join / play surface: mgmt unrestricted; venue leg only
        # from the IETF meeting prefixes + home lab (venue_allowed_* vars in
        # group_vars/playground.yml — confirm prefixes on-site each meeting).
        iifname "eth0" tcp dport 8080 accept
        iifname "eth1" ip saddr { {{ venue_allowed_v4 | join(', ') }} } tcp dport 8080 accept
        iifname "eth1" ip6 saddr { {{ venue_allowed_v6 | join(', ') }} } tcp dport 8080 accept
        # admin over mgmt only
        iifname "eth0" tcp dport 22 accept
        iifname "eth0" icmp type echo-request accept
    }
}
