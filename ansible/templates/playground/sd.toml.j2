[general]
id = "sd1-{{ playground_as }}"
config_dir = "/etc/scion"

[trust_db]
connection = "/var/lib/scion/sd1-{{ playground_as }}.trust.db"

[path_db]
connection = "/var/lib/scion/sd1-{{ playground_as }}.path.db"

[sd]
address = "127.0.0.1:30255"
query_interval = "30s"

[features]
experimental_idint = true

[drkey_level2_db]
connection = "/var/lib/scion/sd1-{{ playground_as }}.drkey_level2.db"

[log.console]
level = "info"
