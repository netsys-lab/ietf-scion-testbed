[Unit]
Description=hev3-server (Happy Eyeballs v3 demo target: IP h2/h1.1/h3 + SCION h3)
# scitra.service ordering matters: the ip-h3 UDP listener enumerates addresses
# at startup and must bind the fc00 scitra-iface (where scitra -p forwards the
# SCION legs). If hev3 starts before scitra's `scion` TUN exists, that fc00:443
# UDP listener is silently missing and the SCION-over-scitra path is dead until
# a restart. So order After scitra, Want it, and gate ExecStart on the fc00
# address actually being present (Type=simple has no readiness signal, and
# scitra brings the TUN up slightly after its process launches).
After=network-online.target scion-sciond.service scitra.service
Wants=network-online.target scitra.service
Requires=scion-sciond.service

[Service]
# Wait (up to 60s) for scitra's `scion` TUN fc00 address before binding, so the
# ip-h3 enumeration always includes it. Cheap no-op once it is up.
ExecStartPre=/bin/bash -c 'for i in $(seq 1 60); do ip -6 addr show scion scope global 2>/dev/null | grep -q "inet6 fc00" && exit 0; sleep 1; done; echo "hev3-server: scion TUN fc00 address not up after 60s" >&2; exit 1'
# -scion also serves native HTTP/3 over SCION QUIC (in addition to the
# always-on IP TCP h2/h1.1 and IP UDP h3 listeners); defaults handle
# -listen-ip (:443), -cert/-key (/etc/hev3/{cert,key}.pem), -scion-port
# (443). SCION_DAEMON_ADDRESS matches the svc endhost sciond's listen
# address (ansible/templates/svc/sd.toml.j2).
# -scion-ip binds the SCION underlay to the fabric SIBLING address .81 so
# the SCION UDP :443 listener can't collide with the ip-h3 :443 listener on
# the fabric primary .80 (commit 7689e3f's collision, same-address variant).
# -listen-http :80 adds the cleartext HTTP leg (TCP; never collides with
# scitra's UDP underlay). -listen-exclude <mgmt IP> keeps the ip-h3 UDP :443
# listener OFF the mgmt address so scitra's `-p 443/80` underlay can bind it
# and forward SCION :443/:80 to this server on the fc00 scitra iface — the
# zone advertises the mgmt SCION identity (scitra --scmp answers `scion ping`
# there); the server is reachable on the fabric .80 + fc00, never on mgmt.
ExecStart=/usr/local/bin/hev3-server -scion -scion-ip {{ fabric_scion_ip }} -listen-http :80 -listen-exclude {{ ansible_eth0.ipv4.address }}
Environment=SCION_DAEMON_ADDRESS=127.0.0.1:30255
Restart=on-failure
# Binds :443 on both the IP and SCION stacks — matches house style for svc
# services (scitra.service, scion-sciond.service both run User=root too).
User=root

[Install]
WantedBy=multi-user.target
