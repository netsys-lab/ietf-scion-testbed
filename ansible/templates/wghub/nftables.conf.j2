#!/usr/sbin/nft -f
flush ruleset

table inet wghub {
    chain forward {
        type filter hook forward priority 0; policy drop;

        # attendee -> own AS attachment only (BR internal + CS of the joinable ASes 152/155/158/161)
        iifname "wg0" oifname "eth0" ip daddr { 10.20.3.152, 10.20.3.155, 10.20.3.158, 10.20.3.161 } meta l4proto { udp, tcp } accept
        iifname "wg0" oifname "eth0" ip daddr { 10.20.3.152, 10.20.3.155, 10.20.3.158, 10.20.3.161 } icmp type echo-request accept

        # attendee -> fleet resolver (WG confs carry DNS=10.20.3.216; the
        # mgmt allowlist above covers only the four AS IPs, so without this
        # the conf's DNS line is dead)
        iifname "wg0" oifname "eth0" ip daddr 10.20.3.216 udp dport 53 accept
        iifname "wg0" oifname "eth0" ip daddr 10.20.3.216 tcp dport 53 accept

        # attendee -> BGP fabric (spec 2026-07-11-bgp-fabric): hev3 races,
        # ping/traceroute/mtr experiments — any protocol, fabric prefixes only
        iifname "wg0" oifname "eth0" ip daddr { 10.150.0.0/16, 10.151.0.0/16, 10.152.0.0/16, 10.153.0.0/16, 10.154.0.0/16, 10.155.0.0/16, 10.156.0.0/16, 10.157.0.0/16, 10.158.0.0/16, 10.159.0.0/16, 10.160.0.0/16, 10.161.0.0/16 } accept
        iifname "wg0" oifname "eth0" ip6 daddr fd00:beef::/32 accept

        # attendee <-> attendee hairpin (same-AS demos), UDP + ping only
        iifname "wg0" oifname "wg0" meta l4proto udp accept
        iifname "wg0" oifname "wg0" icmp type echo-request accept

        # testbed -> attendee: BR-injected delivery is a NEW udp flow
        iifname "eth0" oifname "wg0" meta l4proto udp accept
        iifname "eth0" oifname "wg0" ct state established,related accept
        iifname "eth0" oifname "wg0" icmp type echo-request accept
    }

    chain input {
        type filter hook input priority 0; policy drop;
        iif "lo" accept
        ct state established,related accept
        # v6 housekeeping on the venue leg (SLAAC/ND) and general ICMPv6
        icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert, nd-router-solicit, nd-router-advert, echo-request } accept
        # DHCPv4 client on the venue leg: initial OFFER/ACK arrive as broadcast,
        # which conntrack does not track
        iifname "eth1" udp sport 67 udp dport 68 accept
        # attendees may ping the hub as a first debug step; nothing else
        iifname "wg0" icmp type echo-request accept
        # admin over mgmt only
        iifname "eth0" tcp dport 22 accept
        iifname "eth0" icmp type echo-request accept
        # WG handshake on the venue leg — SOURCE-GATED to the venue allowlist
        # (venue_allowed_v4/v6 in group_vars/playground.yml, the SAME list the
        # dashboard uses). The venue leg is globally routable, so only the IETF
        # meeting prefixes + home/prep networks may even attempt to join —
        # venue attendees are on those prefixes. Widen by editing that var.
        iifname "eth1" ip saddr { {{ venue_allowed_v4 | join(', ') }} } udp dport 51820 accept
        iifname "eth1" ip6 saddr { {{ venue_allowed_v6 | join(', ') }} } udp dport 51820 accept
    }
}
