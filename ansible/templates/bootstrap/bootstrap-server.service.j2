[Unit]
Description=SCION end-host bootstrap server (topology + TRC over HTTP {{ bootstrap_port }})
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
# asnum from the mgmt IP last octet (see deploy_bootstrap_server.yaml). Serves
# the public bootstrap material already installed by deploy_scion_stack.
ExecStart=/usr/bin/python3 /usr/local/lib/scion-bootstrap-server/bootstrap-server.py /etc/scion/AS{{ asnum }} {{ ansible_host }} {{ bootstrap_port }}
DynamicUser=yes
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
