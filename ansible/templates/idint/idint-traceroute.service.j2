[Unit]
Description=ID-INT traceroute server (reflection target, UDP {{ idint_port }})
After=network-online.target scion-daemon.service
Wants=scion-daemon.service
StartLimitIntervalSec=0

[Service]
ExecStart=/usr/local/bin/idint-traceroute --sciond {{ ansible_host }}:30255 --local {{ ansible_host }}:{{ idint_port }}
DynamicUser=yes
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
