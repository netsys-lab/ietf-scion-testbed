# Copy to playground.yml (gitignored real secrets) and edit before deploy.
# Shared booth code — also used by the WG join page and wghubd ttyd auth.
booth_code: "changeme-at-booth"
# Directory on the BUILD host holding the fork-built endhost binaries
# (scion, sciond, shim-dispatcher) produced by Task 2.
scion_bin_src: "{{ playbook_dir }}/../../.build/endhost/bin"

# WG hub endpoints as seen from the venue (set on-site; bare hosts, no port).
wg_endpoint_v6: "2001:db8::changeme"
wg_endpoint_v4: "203.0.113.99"

# Venue-leg (eth1) allowlist for CT200:8080. IETF meeting prefixes
# (https://www.ietf.org/meeting/meeting-network-information/) + home lab.
# Confirm the meeting prefixes on-site each meeting.
venue_allowed_v4: ["31.133.128.0/18", "31.130.224.0/20", "10.0.0.0/24"]
venue_allowed_v6: ["2001:67c:370::/48", "2001:67c:1230::/46"]
